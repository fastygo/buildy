package partials

import (
	"github.com/fastygo/buildy/internal/ui/components/toggles"
	"github.com/fastygo/templ/ui"
)

// HeaderTrailing renders the locale switch in the header bar.
templ HeaderTrailing(language toggles.LanguageSwitchProps) {
	@ui.Group(ui.GroupProps{Class: "flex shrink-0 flex-wrap items-center justify-end gap-2 sm:gap-3"}) {
		@toggles.LanguageSwitch(language)
	}
}
